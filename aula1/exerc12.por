programa
{
    funcao inicio()
    {
        real nota1
        real nota2
        real nota3
        escreva("Digite a primeira nota: ")
        leia(nota1)
        escreva("Digite a segunda nota: ")
        leia(nota2)
        escreva("Digite a terceira nota: ")
        leia(nota3)
        real mediaa = (nota1+nota2+nota3)/3
        escreva("A média das notas é ", mediaa)
    }
}